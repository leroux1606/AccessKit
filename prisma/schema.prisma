// This is the AccessKit Prisma schema
// Source of truth for all database entities

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanType {
  STARTER
  PROFESSIONAL
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  CLIENT_VIEWER
}

enum ScanFrequency {
  DAILY
  WEEKLY
  MONTHLY
  MANUAL
}

enum Standard {
  WCAG21_A
  WCAG21_AA
  WCAG22_AA
  SECTION_508
  EN_301_549
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum TriggerType {
  MANUAL
  SCHEDULED
  CI_CD
  API
}

enum Engine {
  AXE_CORE
  PA11Y
  CUSTOM
}

enum Severity {
  CRITICAL
  SERIOUS
  MODERATE
  MINOR
}

enum Category {
  IMAGES
  FORMS
  COLOR
  KEYBOARD
  ARIA
  STRUCTURE
  MULTIMEDIA
  NAVIGATION
}

enum EffortLevel {
  LOW
  MEDIUM
  HIGH
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  WONT_FIX
  FALSE_POSITIVE
}

enum VerificationMethod {
  META_TAG
  DNS_TXT
  FILE_UPLOAD
}

// ─── Organizations ────────────────────────────────────────────────────────────

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  plan                 PlanType           @default(STARTER)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  whiteLabel           Json?              // { logo, primaryColor, secondaryColor, companyName, customDomain }
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  memberships  Membership[]
  websites     Website[]
  apiKeys      ApiKey[]
  clientPortals ClientPortal[]
}

// ─── Users & Memberships ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
  violations  Violation[] @relation("AssignedViolations")
  comments    IssueComment[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── NextAuth.js tables ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Websites ─────────────────────────────────────────────────────────────────

model Website {
  id                 String              @id @default(cuid())
  organizationId     String
  url                String
  name               String
  verified           Boolean             @default(false)
  verificationToken  String              @default(cuid())
  verificationMethod VerificationMethod?
  currentScore       Int?
  lastScanAt         DateTime?
  scanFrequency      ScanFrequency       @default(MANUAL)
  standards          Standard[]
  isCompetitor       Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scans        Scan[]
  violations   Violation[]
  scanSchedule ScanSchedule?
  clientPortals ClientPortal[]

  @@index([organizationId])
}

// ─── Scans ────────────────────────────────────────────────────────────────────

model Scan {
  id              String     @id @default(cuid())
  websiteId       String
  status          ScanStatus @default(QUEUED)
  score           Int?
  pagesScanned    Int        @default(0)
  pageLimit       Int        @default(50)
  totalViolations Int?
  criticalCount   Int?
  seriousCount    Int?
  moderateCount   Int?
  minorCount      Int?
  duration        Int?       // milliseconds
  triggeredBy     TriggerType @default(MANUAL)
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())

  website    Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  pages      Page[]
  violations Violation[]

  @@index([websiteId, createdAt])
}

// ─── Pages ────────────────────────────────────────────────────────────────────

model Page {
  id             String   @id @default(cuid())
  scanId         String
  url            String
  title          String?
  score          Int?
  violationCount Int      @default(0)
  screenshotUrl  String?
  loadTime       Int?     // milliseconds
  createdAt      DateTime @default(now())

  scan       Scan        @relation(fields: [scanId], references: [id], onDelete: Cascade)
  violations Violation[]

  @@index([scanId])
}

// ─── Violations ───────────────────────────────────────────────────────────────

model Violation {
  id        String @id @default(cuid())
  scanId    String
  pageId    String
  websiteId String

  // Detection
  ruleId   String
  engine   Engine
  severity Severity
  impact   String?
  category Category

  // Standards mapping
  standards     String[]
  wcagCriterion String?
  wcagLevel     String?

  // Details
  description  String
  helpText     String
  helpUrl      String?
  htmlElement  String   @db.Text
  cssSelector  String
  xpath        String?
  screenshotUrl String?

  // Remediation
  fixSuggestion   String?  @db.Text
  aiFixSuggestion String?  @db.Text
  fixedHtml       String?  @db.Text
  effortEstimate  EffortLevel @default(MEDIUM)

  // Workflow
  status       IssueStatus @default(OPEN)
  assignedToId String?
  resolvedAt   DateTime?
  verifiedAt   DateTime?

  // Cross-scan tracking
  fingerprint     String
  firstDetectedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scan       Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("AssignedViolations", fields: [assignedToId], references: [id])
  comments   IssueComment[]

  @@index([fingerprint])
  @@index([websiteId, status])
  @@index([scanId, severity])
}

// ─── Issue Comments ───────────────────────────────────────────────────────────

model IssueComment {
  id                   String   @id @default(cuid())
  violationId          String
  violationFingerprint String
  userId               String
  content              String   @db.Text
  createdAt            DateTime @default(now())

  violation Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([violationId])
  @@index([violationFingerprint])
}

// ─── Scan Schedules ───────────────────────────────────────────────────────────

model ScanSchedule {
  id        String        @id @default(cuid())
  websiteId String        @unique
  frequency ScanFrequency @default(WEEKLY)
  nextRunAt DateTime
  lastRunAt DateTime?
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique // SHA-256 hash, never store plain text
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─── Client Portals ───────────────────────────────────────────────────────────

model ClientPortal {
  id             String  @id @default(cuid())
  organizationId String
  websiteId      String
  slug           String  @unique
  customDomain   String?
  passwordHash   String?
  logoUrl        String?
  primaryColor   String?
  companyName    String?
  enabled        Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
